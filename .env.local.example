# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Price ID for the $149/month subscription
# Create in Stripe Dashboard → Products → Add Product → $149/mo recurring
STRIPE_PRICE_ID=price_YOUR_PRICE_ID

# ─── Mux (Video Hosting) ─────────────────────────────────────────────────────
# Get these from: https://dashboard.mux.com → Settings → API Access Tokens
MUX_TOKEN_ID=YOUR_MUX_TOKEN_ID
MUX_TOKEN_SECRET=YOUR_MUX_TOKEN_SECRET

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://laxlab.com
NEXT_PUBLIC_APP_NAME=Lax Lab
